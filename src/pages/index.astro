---
import Layout from "./layout.astro";
import Hero from "$lib/components/Hero.astro";

const worked = [
  "Anselm Keifer",
  "Damien Hurst",
  "Picasso",
  "Salvador Dali",
  "Barbora Hepworth",
  "Jean Cocteau",
  "Mark Quinn",
  "St Paul’s Cathedral",
  "The Design Museum, London",
  "Hampton Court Palace, London",
  "The Tower of London",
  "The Watts Gallery",
  "Truro Cathedral, Cornwall",
  "The Natural History Museum",
  "Westminster Abbey, London",
  "The Cutty Sark",
  "The Rolling Stones Exhibition",
  "The National Army Museum",
  "Buckingham Palace",
  "The Institute of Civil Engineers",
  "Mathaf Arab Museum Of Modern Art, Doha, Qatar",
  "Forsvarsmuseet, Oslo, Norway",
  "St Paul’s Cathedral, Melbourne, Australia",
  "Mougins Museum of Classical Art, Mougins, France",
];
---

<Layout title="" description="">
  <Hero />
  <section class="content-grid bg-grey text-lg py-12 md:py-24">
    <h1 class="text-2xl md:text-4xl breakout font-normal">
      Specialist in the conservation, repair and cleaning of sculptural works of
      art and objects.
    </h1>
    <div class="flex flex-col items-center breakout text-primary-200">
      <!-- <Icon ctx="vase" size="15em" /> -->
      <!-- <div class="flex flex-col"> -->
      <p class="">
        Providing museum level conservation and restoration services. Working on
        a diverse variety of materials and objects, carrying out practical
        conservation as well as condition assessments, treatment proposals and
        estimates and recommendations.
      </p>
      <!-- </div> -->

      <p class="self-start text-black mt-8">Survey and Treatment of objects.</p>
      <p class="self-start">Including works fabricated in:</p>
      <p class="uppercase text-xl md:text-2xl">
        Stone, Metal, Wood, Marble, Concrete, Mixed media, Modern materials,
        Plastics, Plaster, Painted surfaces, Fine silver, Bronze, Wooden objects
      </p>
    </div>
  </section>
  <section class="content-grid px-8 md:px-0 py-12">
    <div class="wide text-primary-200 grid grid-cols-1 md:grid-cols-2 gap-12">
      <aside data-headshot class="rounded-full w-fit overflow-clip md:h-fit">
        <img class="object-fit" src="/HEADSHOT.webp" alt="anna taylor" />
      </aside>
      <div class="content flex flex-col justify-center text-lg gap-4">
        <p>
          Anna is a British conservator with over 20 years' experience in
          practical conservation and restoration, working on sculptural works of
          art, from ancient to contemporary, and large scale architectural
          projects.
        </p>

        <p>
          She has worked with private collectors, auction houses, insurers,
          commercial galleries, artist’s estates, foundations and public
          institutions and has been involved in the conservation and
          installation of many complex collections and exhibitions in the UK and
          worldwide.
        </p>

        <div class="flex flex-col justify-end pb-8">
          <button
            aria-label="copy email to clipboard"
            data-email="annataylorconservation@gmail.com"
            class="reltive btn-primary hover:bg-accent-200 self-end bg-primary-200 text-amber-50 flex text-2xl justify-center"
          >
            <div class="flex gap-4 items-center">
              Contact by email
              <!-- <Icon ctx="send" size="1em" /> -->
            </div>
            <div id="toast">✅ Email copied to clipboard</div>
          </button>
        </div>

        <div class="flex flex-col gap-8">
          <p class="self-end text-sm md:text-lg">
            Anna is a member of <a href="https://nkf-dk.dk/" class="link"
              >The Nordisk Konservator Forbund</a
            >.
          </p>
        </div>
        <!-- <div class="relative self-end">
          <div
            class="absolute right-0 transform translate-x-16 translate-y-[-5em]"
          >
            <Icon ctx="paintbrush" size="8em" nostroke />
          </div>
        </div> -->
      </div>
    </div>
  </section>
  <aside class="content-grid bg-grey px-8 py-12">
    <div class="wide flex flex-col items-center">
      <h3>Notable Artists and collections and buildings:</h3>
      <!-- <aside class="py-8 px-8 md:px-0"> -->
      <p class="uppercase">
        {
          worked.map((word, index) => (
            <>
              <span>{word}</span>
              {index < worked.length - 1 && (
                <span class="text-primary-200 mx-2">|</span>
              )}
            </>
          ))
        }
      </p>
      <!-- </aside> -->
      <!-- <aside class="flex justify-center">
        <img
          class="max-h-[50vh] md:max-h-[60vh] aspect-square md:aspect-auto object-cover w-full object-top"
          src="https://images.squarespace-cdn.com/content/v1/65cb6cf17c041c7ba0996dbc/6eb8a32e-f81f-44dc-a2d7-0110c06e6937/ad777f53-8cf8-4eaf-859d-3a6d92053cc9.jpg?format=750w"
          alt=""
        />
      </aside> -->
    </div>
  </aside>
</Layout>

<style>
  @reference "$lib/styles/index.css";
  button {
    transition: all 0.3s;
    @apply border-transparent;
  }
  [data-headshot] {
    @media (max-width: 767px) {
      width: calc(100vw - 4em);
      height: calc(100vw - 4em);
      img {
        transform: translateY(-10%);
      }
    }
  }
  #toast {
    position: absolute;
    translate: 0% 0%;
    margin-bottom: 0.5rem;
    @apply bg-black text-amber-100 rounded-full;
    padding: 0.75rem 1.5rem;
    font-size: 0.875rem;
    pointer-events: none;
    white-space: nowrap;
    opacity: 0;
    transition:
      opacity 0.3s,
      translate 0.3s;
  }
  #toast.show {
    opacity: 1;
    translate: 0% -150%;
  }
</style>

<script is:inline>
  function initToast() {
    const toast = document.getElementById("toast");
    const btn = document.querySelector("[data-email]");
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText("annataylorconservation@gmail.com");
      } catch {}
      toast.classList.add("show");
      clearTimeout(toast._hide);
      toast._hide = setTimeout(() => {
        toast.classList.remove("show");
      }, 3000);
    });
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initToast);
  } else {
    initToast();
  }
</script>
