---
// Hero.astro
// const words = ["Sculpture", "& Object", "Conservation"];
---

<div class="grid grid-rows-[auto_auto] md:grid-cols-2">
  <div
    class="hero text-primary-200 font-single font-light uppercase"
    id="hero-container"
  >
    <span class="word">Sculpture & Object</span>
    <span class="word">Conservation and Restoration</span>
  </div>
  <div class="text-primary-200 bg-rose-100 font-single font-light uppercase">
    <div
      class="flex items-center justify-center h-full max-h-full overflow-hidden"
    >
      <img
        src="https://images.squarespace-cdn.com/content/v1/65cb6cf17c041c7ba0996dbc/b694b557-ea4b-444c-8639-143d9452f477/IMG_2404.jpg?format=1080h"
        alt=""
        class="opacity-30 grayscale object-cover object-center w-full h-full"
      />
      <!-- <span>IMAGE</span> -->
    </div>
  </div>
</div>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    max-width: 80vw;
    width: 80%;
    margin: 0 auto;
    min-height: 90dvh;
  }

  @media screen and (max-width: 768px) {
    .hero {
      min-height: 50dvh;
    }
    .grid > div:last-child {
      height: 30dvh;
    }
  }

  .word {
    white-space: nowrap;
    margin: 0;
    padding: 0;
    line-height: 1em;
  }
</style>

<script is:inline data-astro-rerun>
  function fitWordsToWidth() {
    const container = document.getElementById("hero-container");
    const words = container.querySelectorAll(".word");

    words.forEach((word) => {
      // Reset to measure properly
      word.style.fontSize = "";
      const parentWidth = word.parentElement.clientWidth;
      let fontSize = 300; // Start very large
      word.style.fontSize = fontSize + "px";

      // Binary search for better performance with long words
      let min = 0;
      let max = fontSize;

      while (min <= max) {
        const mid = Math.floor((min + max) / 2);
        word.style.fontSize = mid + "px";

        if (word.scrollWidth <= parentWidth) {
          min = mid + 1;
        } else {
          max = mid - 1;
        }
      }

      word.style.fontSize = max + "px";
    });
  }

  // Astro lifecycle events
  document.addEventListener("astro:page-load", fitWordsToWidth);
  document.addEventListener("astro:after-swap", fitWordsToWidth);
  window.addEventListener("resize", fitWordsToWidth);
  document.addEventListener("DOMContentLoaded", fitWordsToWidth);

  // Initial load
  fitWordsToWidth();
  setTimeout(() => {
    fitWordsToWidth();
  }, 100);
</script>
